{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "WebSearch",
      "Write",
      "Glob",
      "Grep",
      "Bash(cat ~/.claude/*)",
      "Bash(edit ~/.claude/*)",
      "Bash(npm test)",
      "Bash(npm run build)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git diff *)",
      "Bash(git status *)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Bash(ln *)",
      "Bash(cat *)",
      "Bash(ls *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(pip show *)",
      "Bash(pip3 show *)",
      "Bash(pip list *)",
      "Bash(pip3 list *)",
      "Bash(python -m pytest *)",
      "Bash(pyenv versions *)",
      "Bash(pyenv version *)",
      "Bash(python -c *)",
      "Bash(python3 -c *)",
      "mcp__playwright__*",
      "mcp__firecrawl__*"
    ],
    "ask": [
      "Bash(rm -rf *)",
      "Bash(git push --force)",
      "Bash(curl *)",
      "Bash(wget *)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf ..*)"
    ],
    "defaultMode": "acceptEdits"
  },
  "statusLine": {
    "type": "command",
    "command": "/Users/ryosuke/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "code-review@claude-code-plugins": true,
    "commit-commands@claude-code-plugins": true,
    "frontend-design@claude-code-plugins": true,
    "security-guidance@claude-code-plugins": true,
    "learning-output-style@claude-code-plugins": true,
    "pr-review-toolkit@claude-code-plugins": true,
    "feature-dev@claude-code-plugins": true,
    "pyright-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true
  }
}